@{
    ViewData["Title"] = "Request Confirmed";
}

<div class="card border-0 shadow-sm p-5 text-center bg-white rounded-3">
    <!-- Success Icon Graphics Context -->
    <div class="mb-4">
        <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
            <i class="bi bi-check-circle-fill" style="font-size: 3rem;"></i>
        </div>
    </div>

    <h2 class="fw-bold text-dark mb-2">Thank You!</h2>
    <p class="text-secondary fs-5 mb-1">Your request has been successfully submitted.</p>
    <p class="text-muted small mb-4">Our dedicated team will review your details and contact you shortly.</p>

    <hr class="my-4 mx-auto w-50 text-muted opacity-25" />

    <div class="d-flex justify-content-center">
        <a class="btn btn-outline-primary px-4 py-2 fw-semibold" href="/Lead/Create">
            <i class="bi bi-plus-lg me-1"></i> Submit Another Request
        </a>
    </div>
</div>v>