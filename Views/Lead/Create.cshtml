@model ReplyFlow.Features.Leads.CreateLead.CreateLeadViewModel

<h2>Get Started</h2>

<form asp-action="Create" method="post" class="card p-3 shadow">

    <input asp-for="Name" class="form-control" placeholder="Full Name" />
    <span asp-validation-for="Name" class="text-danger"></span>

    <input asp-for="Phone" class="form-control mt-2" placeholder="Phone Number" />
    <span asp-validation-for="Phone" class="text-danger"></span>

    <select asp-for="BusinessType"
            asp-items="ViewBag.BusinessTypes"
            class="form-select mt-2">
    </select>

    <button type="submit" class="btn btn-primary mt-3">
        Submit
    </button>

</form>

@if (ViewBag.Message != null)
{
    <div class="alert alert-info mt-3">
        @ViewBag.Message
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}